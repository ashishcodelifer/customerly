{
  "$schema": "https://turbo.build/schema.json",
  "pipeline": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        ".next/**",
        "!.next/cache/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "test": {},
    "db:generate": {},
    "db:push": {},
    "db:studio": {}
  },
  "globalEnv": [
    "DATABASE_URL",
    "NEXTAUTH_SECRET"
  ]
}